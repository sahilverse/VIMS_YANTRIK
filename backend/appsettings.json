{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "[JWT_ISSUER]",
    "Audience": "[JWT_AUDIENCE]",
    "Key": "[JWT_SECRET_KEY_PLACEHolder]",
    "ExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "FrontendUrl": "[FRONTEND_URL]",
  "AdminUser": {
    "Email": "[ADMIN_EMAIL]",
    "Password": "[ADMIN_PASSWORD]",
    "FullName": "System Administrator"
  },
  "AllowedHosts": "*"
}